        "team": "T001"
      },
      {
        "type": "message",
        "user": "U010",
        "text": "Heads up \u2014 I'll be working from the Ft. Lauderdale satellite office on Thursday and Friday this week. Reachable by Slack/phone as usual.",
        "ts": "1772027400.002800",
        "team": "T001"
      },
      {
        "type": "message",
        "user": "U002",
        "text": "Happy Monday everyone. Quick reminder: daylight saving time started yesterday \u2014 make sure any manually set calendar reminders are adjusted.",
