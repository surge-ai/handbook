        "thread_ts": "1806055200.000100",
        "parent_user_id": "U018",
        "team": "T001"
      },
      {
        "type": "message",
        "user": "U009",
        "text": "Found the issue - network switch in the accounting office needs a reboot. Should be back up in 5 minutes.",
