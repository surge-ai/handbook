        "required": [
          "issue_key",
          "fields"
        ],
        "type": "object"
      },
      "outputSchema": {
        "additionalProperties": true,
        "type": "object"
      }
    },
    {
      "name": "update_sprint",
      "description": "Update Jira sprint.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "sprint_id": {
            "description": "Jira sprint ID, for example 1001",
            "pattern": "^\\d+$",
            "type": "string"
          },
          "sprint_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "state": {
            "anyOf": [
              {
                "enum": [
                  "active",
                  "closed",
                  "future"
