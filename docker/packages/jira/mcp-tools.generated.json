    {
      "name": "link_issues",
      "description": "Create a bidirectional link between two Jira issues.\n\nlink_type may be a configured link type name or one of its inward/outward\nlabels, such as Blocks, blocks, or is blocked by. Inward labels resolve to\nthe same canonical link type with direction reversed. Default link types are\nBlocks, Cloners, Duplicate, and Relates; call get_link_types to inspect the\ncurrent world's configured link types.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "inward_issue_key": {
