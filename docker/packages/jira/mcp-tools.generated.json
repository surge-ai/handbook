{
  "schema_version": "v1",
  "tools": [
    {
      "name": "add_attachment",
      "description": "Attach a base64-encoded file to a Jira issue.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "issue_key": {
            "description": "Jira issue key, for example MOCK-1",
            "pattern": "^[A-Z][A-Z0-9_]*-\\d+$",
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "content_base64": {
            "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
            "type": "string"
          },
          "mime_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "site_id": {
            "default": "default",
            "description": "Jira site ID. Defaults to the default site.",
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "issue_key",
          "filename",
          "content_base64"
        ],
        "type": "object"
      },
      "outputSchema": {
        "additionalProperties": true,
        "type": "object"
      }
    },
