            "type": "string"
          },
          "comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "site_id": {
            "default": "default",
            "description": "Jira site ID. Defaults to the default site.",
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
