      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "issue_key": {
            "description": "Jira issue key, for example MOCK-1",
            "pattern": "^[A-Z][A-Z0-9_]*-\\d+$",
            "type": "string"
          },
          "transition_id": {
            "description": "Jira workflow transition ID",
            "pattern": "^\\d+$",
            "type": "string"
          },
